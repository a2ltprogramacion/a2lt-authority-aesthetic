---
// @src/components/organisms/CasosClinicos.astro
import { Image } from "astro:assets";

import { mdToHtml } from "../../utils/markdown";

interface Props {
  data: any[]; // Arreglo de casos clínicos
  sectionData?: {
    pre_title?: string;
    title?: string;
    subtitle?: string;
  };
}

const { data, sectionData } = Astro.props;

if (!data || data.length === 0) return null;

const preTitle = sectionData?.pre_title || "Nuestra Excelencia";
const title = sectionData?.title || "Casos Clínicos";
const subtitle =
  sectionData?.subtitle ||
  "Resultados muy naturales con base científica. Desliza para ver la transformación de nuestros pacientes.";

// Pre-procesamos los casos para permitir Markdown asíncrono en las tarjetas
const processedCases = await Promise.all(
  data.slice(0, 4).map(async (caso) => ({
    ...caso,
    htmlTitle: await mdToHtml(caso.data.title),
    htmlDescription: await mdToHtml(caso.data.description),
  })),
);
---

<section
  id="casos-clinicos"
  class="min-h-dvh flex items-center scroll-mt-20 relative w-full bg-transparent overflow-hidden pb-20"
>
  <div class="container mx-auto px-6 max-w-7xl">
    <div
      class="text-center md:text-left mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-6"
    >
      <div class="max-w-3xl">
        <h2
          class="text-sm uppercase tracking-widest text-neon font-bold mb-3 [&_p]:inline [&_p]:m-0 [&_strong]:text-neon"
        >
          <Fragment set:html={await mdToHtml(preTitle)} />
        </h2>
        <h3
          class="text-3xl lg:text-5xl font-heading font-bold text-white mb-4 [&_p]:inline [&_p]:m-0 [&_strong]:text-neon"
        >
          <Fragment set:html={await mdToHtml(title)} />
        </h3>
        <div
          class="text-text-muted text-lg font-light max-w-2xl [&_p]:inline [&_p]:m-0 [&_strong]:text-neon"
        >
          <Fragment set:html={await mdToHtml(subtitle)} />
        </div>
      </div>
    </div>

    {/* Grilla de casos clínicos */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {
        processedCases.map((caso, index) => {
          return (
            <div class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-200 shadow-lg group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
              {/* Slider Container */}
              <div
                class="relative w-full aspect-square overflow-hidden image-comparator bg-black/50"
                style="--slider-pos: 50%;"
              >
                {/* Imagen AFTER (Fondo - Completa) */}
                <div class="absolute inset-0 w-full h-full">
                  <Image
                    src={caso.data.image_after}
                    alt={`Caso Clínico Después - ${caso.data.title}`}
                    class="w-full h-full object-cover object-center pointer-events-none"
                    loading={index < 2 ? "eager" : "lazy"}
                  />
                  <div class="absolute top-4 right-4 bg-white/90 backdrop-blur text-slate-700 text-xs px-3 py-1 rounded-full border border-slate-200 z-0 font-semibold">
                    Después
                  </div>
                </div>

                {/* Imagen BEFORE (Superpuesta - Recortada con Clip Path) */}
                <div
                  class="absolute inset-0 w-full h-full z-0"
                  style="clip-path: polygon(0 0, var(--slider-pos) 0, var(--slider-pos) 100%, 0 100%);"
                >
                  <Image
                    src={caso.data.image_before}
                    alt={`Caso Clínico Antes - ${caso.data.title}`}
                    class="absolute inset-0 w-full h-full object-cover object-center pointer-events-none"
                    loading={index < 2 ? "eager" : "lazy"}
                  />
                  <div class="absolute top-4 left-4 bg-white/90 backdrop-blur text-slate-700 text-xs px-3 py-1 rounded-full border border-slate-200 z-0 font-semibold">
                    Antes
                  </div>
                </div>

                {/* Línea divisoria y Handle */}
                <div
                  class="absolute inset-y-0 w-1 bg-white shadow-[0_0_10px_rgba(0,0,0,0.5)] transform -translate-x-1/2 flex items-center justify-center pointer-events-none z-10"
                  style="left: var(--slider-pos);"
                >
                  <div class="w-10 h-10 bg-white rounded-full shadow-[0_4px_10px_rgba(0,0,0,0.3)] flex items-center justify-center border border-gray-200">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-5 h-5 text-gray-800"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 9l4-4 4 4m0 6l-4 4-4-4"
                        transform="rotate(90 12 12)"
                      />
                    </svg>
                  </div>
                </div>

                {/* Input Range: Interfaz invisible interactiva */}
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="50"
                  class="absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-20 m-0 p-0"
                  aria-label={`Deslizador antes y después para ${caso.data.title}`}
                />
              </div>

              {/* Content info */}
              <div class="p-4 lg:p-5 grow flex flex-col">
                <span class="inline-block bg-slate-200 text-slate-700 text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider mb-2 self-start">
                  {caso.data.procedure}
                </span>
                <h4 class="text-base lg:text-lg font-bold text-text mb-2 leading-tight [&_p]:inline [&_p]:m-0 [&_strong]:text-neon">
                  <Fragment set:html={caso.htmlTitle} />
                </h4>
                <div class="text-text-muted text-xs lg:text-sm line-clamp-2 mt-auto self-start [&_p]:inline [&_p]:m-0 [&_strong]:text-neon">
                  <Fragment set:html={caso.htmlDescription} />
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  // Inicializamos los deslizadores en el cliente
  function initComparators() {
    const comparators = document.querySelectorAll(".image-comparator");

    comparators.forEach((comp) => {
      const input = comp.querySelector(
        'input[type="range"]',
      ) as HTMLInputElement;

      input.addEventListener("input", (e) => {
        const value = (e.target as HTMLInputElement).value;
        (comp as HTMLElement).style.setProperty("--slider-pos", `${value}%`);
        (comp as HTMLElement).style.setProperty("--slider-value", value);
      });
    });
  }

  // Ejecutamos en la primera carga y en navegaciones de Astro
  document.addEventListener("DOMContentLoaded", initComparators);
  document.addEventListener("astro:page-load", initComparators);
</script>
