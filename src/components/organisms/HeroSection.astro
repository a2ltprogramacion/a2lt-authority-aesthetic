---
// @src/components/organisms/HeroSection.astro
import { Image } from "astro:assets";
import { mdToHtml } from "../../utils/markdown";

interface Props {
  data: {
    bg_variant: "image" | "color";
    bg_color?: string;
    image?: any;
    image_mobile?: any;
    image_alt?: string;
    title: string;
    subtitle?: string;
    cta_text: string;
    cta_link: string;
  };
}

const { data } = Astro.props;
const solidColor = data.bg_color || "var(--color-primary)";
---

<section
  id="hero"
  class="relative min-h-screen pt-20 flex items-center justify-center overflow-hidden bg-transparent"
>
  {/* CAPA DE FONDO: IMAGEN PRINCIPAL (DUAL ROBUST) */}
  {
    data.bg_variant === "image" && data.image && (
      <div class="absolute inset-0 z-0">
        {/* Imagen Desktop */}
        <Image
          src={data.image}
          alt={
            data.image_alt ||
            `Imagen principal de ${data.title.replace(/[*_]/g, "")}`
          }
          loading="eager"
          class="hidden md:block w-full h-full object-cover object-top mask-[linear-gradient(to_right,rgba(0,0,0,0.1)_0%,rgba(0,0,0,1)_60%,rgba(0,0,0,1)_100%)]"
        />
        {/* Imagen Móvil */}
        <Image
          src={data.image_mobile || data.image}
          alt={
            data.image_alt ||
            `Imagen principal de ${data.title.replace(/[*_]/g, "")}`
          }
          loading="eager"
          class="block md:hidden w-full h-full object-cover object-top opacity-50 mix-blend-luminosity"
        />

        {/* Overlay gradiente denso izquierdo para leer texto sobre imagen */}
        <div class="absolute inset-0 bg-linear-to-r from-white via-white/10 to-transparent" />
        {/* Glow clínico sutil */}
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_left,var(--color-neon-glow)_0%,transparent_50%)] opacity-30 mix-blend-screen pointer-events-none" />
      </div>
    )
  }

  {/* CONTENIDO DIVIDIDO EN DESKTOP, APILADO EN MÓVIL */}
  <div
    class="container mx-auto px-6 relative z-10 grid grid-cols-1 md:grid-cols-2 gap-8 items-center"
  >
    <div
      class="flex flex-col items-center md:items-start text-center md:text-left"
    >
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-black italic mb-6 tracking-tight leading-tight hero-title"
      >
        <Fragment set:html={mdToHtml(data.title)} />
      </h1>

      {
        data.subtitle && (
          <div class="text-lg md:text-xl text-text-muted mb-10 max-w-xl font-light [&_strong]:text-neon [&_p]:inline [&_p]:m-0">
            <Fragment set:html={mdToHtml(data.subtitle)} />
          </div>
        )
      }

      <a
        href={data.cta_link}
        class="inline-flex items-center justify-center bg-white text-slate-700 font-bold py-4 px-10 rounded-full border border-slate-200 hover:border-accent hover:text-slate-900 hover:shadow-[0_0_20px_var(--color-neon-glow)] reveal text-lg transition-all duration-300 hover:-translate-y-1"
      >
        {data.cta_text}
      </a>
    </div>

    {
      /* Espacio vacío en desktop para dejar ver la imagen de la doctora a la derecha */
    }
    <div class="hidden md:block"></div>
  </div>

  {/* Soft fade para la transición con la sección inferior */}
  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-background to-transparent pointer-events-none z-20"
  >
  </div>
</section>
