---
// @src/components/organisms/FaqSection.astro
interface Props {
  data: {
    question: string;
    answer: string;
  }[];
  sectionData?: {
    title?: string;
    subtitle?: string;
  };
}

const { data, sectionData } = Astro.props;
const title = sectionData?.title || "Preguntas Frecuentes";

import { mdToHtml } from "../../utils/markdown";

type FaqItemWithHtml = (typeof data)[number] & { answerHtml: string };
let processedData: FaqItemWithHtml[] = [];
if (data && data.length > 0) {
  processedData = await Promise.all(
    data.map(async (item) => ({
      ...item,
      answerHtml: await mdToHtml(item.answer),
    })),
  );
}
---

{
  processedData.length > 0 && (
    <section
      id="faq"
      class="min-h-dvh flex items-center scroll-mt-20 relative w-full bg-transparent overflow-hidden pb-20"
    >
      <div class="container mx-auto px-6 max-w-3xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl lg:text-5xl font-heading font-bold text-text mb-4 [&_p]:inline [&_p]:m-0 [&_strong]:text-neon">
            <Fragment set:html={await mdToHtml(title)} />
          </h2>
        </div>

        <div class="space-y-4">
          {processedData.map((item) => (
            <details class="group bg-surface/40 backdrop-blur-md rounded-xl border border-black/5 open:border-neon transition-all duration-300 reveal shadow-sm hover:shadow-md">
              <summary class="flex cursor-pointer items-center justify-between p-6 font-medium text-text select-none bg-white/20 rounded-t-xl group-open:bg-white/40 transition-colors">
                <span class="font-heading text-lg font-bold">
                  {item.question}
                </span>
                <span class="transition-transform duration-300 group-open:rotate-180 text-text-muted text-xl bg-background p-2 rounded-full shadow-sm">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-text-muted leading-relaxed pt-4 mt-2 bg-white/10 rounded-b-xl">
                <Fragment set:html={item.answerHtml} />
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}
