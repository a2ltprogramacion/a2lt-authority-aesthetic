---
// @src/components/organisms/StickyCTA.astro
interface Props {
  enabled: boolean;
  label: string;
  link: string;
  icon: "whatsapp" | "phone" | "calendar";
}

const { enabled, label, link, icon } = Astro.props;

if (!enabled) return null;

// Normaliza el link
let finalLink = link;
if (icon === "whatsapp") {
  const cleanPhone = link.replace(/\D/g, "");
  finalLink = `https://wa.me/${cleanPhone}`;
} else if (icon === "phone") {
  const cleanPhone = link.replace(/\D/g, "");
  finalLink = `tel:+${cleanPhone}`;
}
---

<div class="fixed bottom-6 right-6 z-50 md:hidden animate-bounce-in">
  <a
    href={finalLink}
    target={icon === "whatsapp" ? "_blank" : "_self"}
    rel={icon === "whatsapp" ? "noopener noreferrer" : ""}
    class="relative group flex items-center justify-center w-16 h-16 bg-[#25D366] rounded-full shadow-[0_10px_25px_rgba(37,211,102,0.4)] hover:scale-110 active:scale-95 transition-all duration-300 overflow-visible"
    aria-label={label}
  >
    {/* Efecto de Pulso Externo Controlado por JS */}
    <span
      id="cta-pulse-ring"
      class="absolute inset-0 rounded-full bg-[#25D366] opacity-0 pointer-events-none"
    ></span>

    {/* Tooltip Lateral */}
    <span
      class="absolute right-20 bg-white text-slate-800 text-xs font-bold py-2 px-4 rounded-lg shadow-xl opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap border border-slate-100 pointer-events-none"
    >
      {label}
    </span>

    {/* Icono Principal (Forzado a Blanco) */}
    {
      icon === "whatsapp" && (
        <svg
          class="w-8 h-8 relative z-10 text-white fill-white"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413Z" />
        </svg>
      )
    }
  </a>
</div>

<script is:inline>
  function setupStickyPulse() {
    const pulseRing = document.getElementById("cta-pulse-ring");
    if (!pulseRing) return;

    function triggerPulse() {
      // Aplicar animación
      pulseRing.classList.add("animate-pulse-once");

      // Limpiar y esperar intervalo aleatorio
      setTimeout(() => {
        pulseRing.classList.remove("animate-pulse-once");

        // Intervalo aleatorio entre 10s (10000ms) y 20s (20000ms)
        const nextInterval = Math.floor(
          Math.random() * (15000 - 5000 + 1) + 5000,
        );
        setTimeout(triggerPulse, nextInterval);
      }, 2000); // 2 segundos para dar tiempo a la animación de expansión
    }

    // Iniciar el ciclo
    setTimeout(triggerPulse, 3000); // Esperar 3s tras carga inicial para el primer pulso
  }

  // Ejecutar en carga y tras navegación (si usas View Transitions)
  setupStickyPulse();
  document.addEventListener("astro:after-swap", setupStickyPulse);
</script>

<style>
  @keyframes bounceIn {
    0% {
      transform: scale(0);
      opacity: 0;
    }
    60% {
      transform: scale(1.1);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  @keyframes pulseOnce {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  .animate-bounce-in {
    animation: bounceIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  .animate-pulse-once {
    animation: pulseOnce 2s cubic-bezier(0, 0, 0.2, 1) forwards;
  }
</style>
